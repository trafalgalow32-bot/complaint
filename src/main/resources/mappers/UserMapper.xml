<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.complaint.repository.UserRepo">

    <select id="findById" parameterType="string"
            resultType="com.complaint.Entity.User">
        select * from user2 where userId=#{userId}
    </select>

    <insert id="save" parameterType="com.complaint.Entity.User">
        insert into user2 ( userId, name, email, password, tel , role)
            values(#{userId}, #{name}, #{email}, #{password}, #{tel}, #{role})
    </insert>

</mapper>