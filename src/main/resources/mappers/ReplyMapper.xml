<?xml version="1.0" encoding="UTF-8" ?>
<!--ReplyMapper.xml-->

<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.complaint.repository.ReplyRepo">
    <select id="findById" resultType="com.complaint.Entity.ComplainReply">
        select * from complain_reply
        where complain_id=#{id};
    </select>
</mapper>